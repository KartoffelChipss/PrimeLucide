{
    "name": "primelucide",
    "version": "1.0.0",
    "scripts": {
        "build": "tsc && copyfiles -u 1 src/**/*.css dist",
        "start": "node dist/index.js",
        "go": "npm run build && npm run start",
        "maven-install": "mvn install:install-file -Dfile=./out/prime-lucide.jar -DgroupId=org.strassburger -DartifactId=prime-lucide -Dversion=1.0.0 -Dpackaging=jar"
    },
    "license": "Apache 2.0",
    "packageManager": "pnpm@10.33.0",
    "dependencies": {
        "jszip": "^3.10.1",
        "lightningcss": "^1.32.0",
        "lucide-static": "^1.16.0"
    },
    "devDependencies": {
        "@types/archiver": "^7.0.0",
        "@types/jszip": "^3.4.1",
        "@types/node": "^25.9.1",
        "copyfiles": "^2.4.1",
        "typescript": "^6.0.3"
    }
}
